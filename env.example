# ─── SYSTEM ────────────────────────────────────────────────────────────────
TZ=America/Toronto
SERVER_IP=192.168.0.0

# User/group IDs — run `id` on the server to get these
PUID=1000
PGID=1000

# ─── PATHS ─────────────────────────────────────────────────────────────────
MEDIA_DIR=/home/aurikd/media
CONFIG_DIR=/home/aurikd/homestudio/config

# ─── MULLVAD WIREGUARD ─────────────────────────────────────────────────────
# Generate from: https://mullvad.net/en/account/#/wireguard-config
# Select: Linux, WireGuard, Canada
MULLVAD_PRIVATE_KEY=your_wireguard_private_key_here
MULLVAD_ADDRESSES=10.x.x.x/32  # assigned address from Mullvad config
